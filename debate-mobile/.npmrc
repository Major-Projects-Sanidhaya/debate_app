# @config-plugins/react-native-webrtc declares peer support up to Expo SDK 56
# while this app is on SDK 57, so a strict install fails with ERESOLVE. The
# plugin only writes camera/mic permissions into the native projects at
# prebuild and works fine on 57.
#
# This file matters for more than local installs: EAS runs `npm install` on the
# build machine, and without it the cloud build fails before it compiles
# anything.
legacy-peer-deps=true
