# Copy to .env and adjust. Values below match debate-infra defaults.
POSTGRES_URL=postgresql+asyncpg://debate:debate@localhost:5432/debate
REDIS_URL=redis://localhost:6379/0

# LIVEKIT_URL is handed to clients in match_found — physical phones need your
# Mac's LAN IP here (see debate-infra README), the iOS simulator is fine with
# localhost.
LIVEKIT_URL=ws://192.168.x.x:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me

# HS256 secret for the app's own auth JWTs (>= 32 bytes). Change outside local dev.
JWT_SECRET=dev_jwt_secret_change_me_min_32_bytes_long

# Shared secret debate-agent sends as X-Internal-Key on moderation events.
INTERNAL_API_KEY=dev_internal_key_change_me

# Comma-separated list, or * for any origin.
CORS_ORIGINS=*
