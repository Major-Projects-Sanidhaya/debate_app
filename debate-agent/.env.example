# "development" (default) or "production". ENV=production refuses to start
# with dev credentials or a missing provider/Deepgram/internal key — see DEPLOY.md.
ENV=development

# LiveKit dev server from debate-infra (make up there first)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me

# Deepgram streaming STT — https://console.deepgram.com
DEEPGRAM_API_KEY=

# LLM provider: "gemini" (default — free AI Studio tier) or "anthropic"
LLM_PROVIDER=gemini

# Google AI Studio — free key at https://aistudio.google.com/apikey
# Note: free-tier prompts may be used by Google for product improvement.
GEMINI_API_KEY=
GEMINI_EXTRACTION_MODEL=gemini-2.5-flash-lite
GEMINI_VERIFICATION_MODEL=gemini-2.5-flash

# Anthropic API — https://console.anthropic.com (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

REDIS_URL=redis://localhost:6379/0

# --- moderation -------------------------------------------------------------
# debate-api's internal moderation intake; INTERNAL_API_KEY must match the
# INTERNAL_API_KEY set in debate-api's .env.
INTERNAL_API_URL=http://localhost:8000
INTERNAL_API_KEY=dev_internal_key_change_me

# DEV ONLY — must be blank in production. When set, any finalized transcript
# segment containing this phrase (case-insensitive) synthesizes a severe
# "test" moderation event without calling the model, which terminates the
# match. Used to exercise the end-to-end moderation path on demand.
MODERATION_TEST_PHRASE=

# Video moderation: one frame sampled per interval per speaker, classified in
# memory and discarded. Set VIDEO_MODERATION_ENABLED=false to skip video
# entirely (the agent then subscribes to audio only).
VIDEO_MODERATION_ENABLED=true
VIDEO_SAMPLE_INTERVAL=10
