# LiveKit dev server from debate-infra (make up there first)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me

# Deepgram streaming STT — https://console.deepgram.com
DEEPGRAM_API_KEY=

# LLM provider: "gemini" (default — free AI Studio tier) or "anthropic"
LLM_PROVIDER=gemini

# Google AI Studio — free key at https://aistudio.google.com/apikey
# Note: free-tier prompts may be used by Google for product improvement.
GEMINI_API_KEY=
GEMINI_EXTRACTION_MODEL=gemini-2.5-flash-lite
GEMINI_VERIFICATION_MODEL=gemini-2.5-flash

# Anthropic API — https://console.anthropic.com (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

REDIS_URL=redis://localhost:6379/0
