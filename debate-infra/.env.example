# Copy to .env here and into the app repos (debate-api, debate-mobile).
# Dev values only — nothing here is a real secret.

# Your Mac's IP on the local Wi-Fi network. Find it with `make lan-ip`.
# Physical devices reach LiveKit through this IP; see README for why.
LAN_IP=192.168.x.x

# debate-api (FastAPI)
POSTGRES_URL=postgresql+asyncpg://debate:debate@localhost:5432/debate
REDIS_URL=redis://localhost:6379/0

# LiveKit. ${LAN_IP} expands under docker compose and most dotenv loaders;
# if your loader doesn't interpolate, write the IP literally.
LIVEKIT_URL=ws://${LAN_IP}:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me

# Optional host-port overrides, picked up by docker compose. Use these when
# something local already owns the default port (e.g. an installed Postgres
# on 5432). If you change POSTGRES_PORT, update POSTGRES_URL to match.
# POSTGRES_PORT=5433
# GRAFANA_PORT=3001
